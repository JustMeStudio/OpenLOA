### --- OpenLOA 特定排除项 ---
# 排除你提到的本地项目存储和向量数据库
/backend/projects/
/backend/chroma_db/

# 忽略包含私密 Key 的真实配置文件
/configs/models.yaml
/configs/tools.yaml

### --- Python 常见缓存与环境 ---
# 字节码文件
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境 (常用目录名)
venv/
.venv/
env/
ENV/
bin/
include/
lib/

# 外部库文件夹 (由 pip 安装)
/site/

### --- 开发工具与系统文件 ---
# 编辑器配置 (VS Code / PyCharm)
.vscode/
.idea/

# 操作系统临时文件
.DS_Store
Thumbs.db

### --- 打包与发布 ---
# PyInstaller 打包生成的目录
build/
dist/
*.spec

# 项目依赖与元数据
*.egg-info/
.installed.cfg
*.egg
MANIFEST

### --- 日志与本地配置 ---
# 运行日志
*.log
# 本地环境变量配置文件
.env